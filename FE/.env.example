# ==============================================================================
# AEROSTRIDE - FRONTEND ENVIRONMENT CONFIGURATION
# ==============================================================================

# API Configuration
VITE_API_URL=/api/v1
VITE_WS_URL=/ws

# Application Settings
# Absolute public origin, interpolated into index.html's JSON-LD block as
# %VITE_APP_URL% (canonical url, logo, search action target).
VITE_APP_URL=https://aerostride.me

# --- DEV SERVER (vite.config.js) ---
# These are NOT VITE_-prefixed on purpose: they configure the dev server itself
# and must never be exposed to client code. vite.config.js reads them through
# loadEnv(mode, cwd, '') to build the /api, /uploads, /ws and /ws-chat proxies.
# Values below are for running `npm run dev` on the HOST. Inside Docker the
# compose file injects BACKEND_HOST=aerostride-be as a real environment
# variable, and Vite gives process.env priority over this file, so the
# container keeps working without editing anything here.
BACKEND_HOST=localhost
BACKEND_PORT=8080
FE_DEV_PORT=5173
