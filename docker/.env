# ==============================================================================
# AEROSTRIDE - DOCKER ENVIRONMENT CONFIGURATION (.env)
# ==============================================================================

# MYSQL CONFIGURATION (Dùng cho container 'db')
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=aerostride_db

# BACKEND CONFIGURATION
# Lưu ý: 'aerostride-db' là tên container của MySQL trong docker-compose
SPRING_DATASOURCE_URL=jdbc:mysql://aerostride-db:3306/aerostride_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# REDIS CONFIGURATION
# Lưu ý: 'redis' là tên service của Redis trong docker-compose
REDIS_HOST=redis
REDIS_PORT=6379
SPRING_CACHE_TYPE=redis

# APP CONFIGURATION
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_API_PREFIX=/api/v1

# FRONTEND CONFIGURATION
VITE_API_URL=http://localhost:8080/api

