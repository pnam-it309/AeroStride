# MySQL Configuration
MYSQL_ROOT_PASSWORD=aerostride_root_pass
MYSQL_DATABASE=aerostride_db
MYSQL_USER=aerostride_user
MYSQL_PASSWORD=aerostride_pass

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/aerostride_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=aerostride_user
SPRING_DATASOURCE_PASSWORD=aerostride_pass
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
SPRING_CACHE_TYPE=redis
