# Static Gradle config mounted INTO the backend container over /app/gradle.properties.
# This shields the container from BE/gradle.properties on the host (which may contain
# ${ENV} placeholders that Gradle cannot parse). Override org.gradle.* via GRADLE_OPTS
# (-Dorg.gradle.workers.max=N ...) from docker/.env if you need per-environment values.
#
# Two Gradle daemons live in this container at once (bootRun holds one, the
# dev watcher's `gradlew classes` uses another), so the daemon heap below is
# deliberately modest - the application JVM gets the rest via BOOT_RUN_JVM_ARGS.
org.gradle.daemon=true
org.gradle.parallel=true
org.gradle.workers.max=2
org.gradle.caching=true
# bootRun is a long-running forked JavaExec; the configuration cache trips over it
# and re-runs configuration on every incremental compile. Off in dev.
org.gradle.configuration-cache=false
# inotify does not cross a Docker bind mount from a Windows host, so file-system
# watching only costs memory here. The dev watcher polls mtimes instead.
org.gradle.vfs.watch=false
# Release the compile daemon's memory when idle - RAM is the scarce resource here.
org.gradle.daemon.idletimeout=180000
org.gradle.jvmargs=-Xms128m -Xmx512m -XX:MaxMetaspaceSize=256m -XX:+UseG1GC -XX:TieredStopAtLevel=1 -Dfile.encoding=UTF-8
