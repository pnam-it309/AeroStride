# --- Docker Images (Optional) ---
BACKEND_IMAGE=ghcr.io/pnam-it309/aerostride/backend:latest
FRONTEND_IMAGE=ghcr.io/pnam-it309/aerostride/frontend:latest

# --- Ports Configuration ---
# BE_PORTInternal: Port of the Spring Boot app inside the container
BE_PORTInternal=8080
# BE_PORTExternal: Port exposed on the host machine
BE_PORTExternal=8080

# FE_PORTInternal: Port of Nginx inside the container
FE_PORTInternal=8080
# FE_PORTExternal: Port you use to access the website (usually 80 or 443)
FE_PORTExternal=80

# Redis & Database Port mapping
REDIS_PORT=6379
MYSQL_PORT_HOST=3307
MYSQL_PORT_INTERNAL=3306

# --- API & Security ---
# Should stay as /api/v1 for most use cases
VITE_API_URL=/api/v1
JWT_SECRET=your_super_secret_jwt_key_here

# --- Database Credentials ---
MYSQL_ROOT_PASSWORD=aerostride_root_pass
MYSQL_DATABASE=aerostride
MYSQL_USER=aerostride_user
MYSQL_PASSWORD=aerostride_pass