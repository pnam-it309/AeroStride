# ==============================================================================
# AEROSTRIDE - ENVIRONMENT CONFIGURATION (.env.example)
# Copy file này thành .env và điền giá trị thật
# ==============================================================================

# --- DOCKER IMAGES ---
BACKEND_IMAGE=aerostride-backend:dev
FRONTEND_IMAGE=aerostride-frontend:dev
MOBILE_IMAGE=aerostride-mobile:dev
MCP_SERVER_IMAGE=aerostride-mcp-server:dev
REDIS_IMAGE=redis:7-alpine
MYSQL_IMAGE=mysql:8.0
NGINX_IMAGE=nginx:alpine

# --- PROFILE "full" SERVICES (mcp-server, nginx-proxy) ---
HTTP_PORT_HOST=8000
NGINX_ROOT_FE=/usr/share/nginx/html
NGINX_ROOT_PROXY=/usr/share/nginx/html

# --- NETWORKING PORTS ---
BACKEND_PORT=8080
NGINX_PORT=80
FE_PORTExternal=5173

# --- DATABASE (MYSQL) ---
MYSQL_PORT_HOST=3307
MYSQL_DATABASE=aerostride_db
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/aerostride_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_user
SPRING_DATASOURCE_PASSWORD=your_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Comma-separated auto-config classes to exclude at runtime. Empty by default.
SPRING_AUTOCONFIGURE_EXCLUDE=

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
# Published to the host so a locally-run backend can reach the dockerised Redis.
REDIS_PORT_HOST=6379
SPRING_CACHE_TYPE=redis

# --- APP SETTINGS ---
# Backend timezone — must match users' timezone so date filters (tuNgay/denNgay) parse
# "today" correctly. Keep UTC only if your users are in UTC.
APP_TZ=Asia/Ho_Chi_Minh
SPRING_PROFILES_ACTIVE=mysql
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080
# Public storefront origin, used for absolute SEO URLs (product sitemap).
# /product/{id} is a Vue route, so this is the FRONTEND host - different from
# APP_BASE_URL in local dev. In production both sit behind nginx on one domain,
# so set this to https://aerostride.me there (keep it equal to VITE_APP_URL).
APP_PUBLIC_URL=http://localhost:5173
APP_API_PREFIX=/api/v1
# Comma-separated (SecurityConfig splits it): Vite app + Expo web.
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:8081
ACTUATOR_ENDPOINTS=health,info,metrics

# --- AI CHATBOT & MCP ---
# MCP_CLIENT_ENABLED MUST be false unless the mcp-server container is running
# (`docker compose --profile full up`). Otherwise backend crashes at startup
# because it cannot resolve aerostride-mcp-server (AI bean chain fails).
MCP_CLIENT_ENABLED=false
MCP_SERVER_PORT=3000
MCP_SERVER_PORT_HOST=3000
# Host/port here must match the container name and MCP_SERVER_PORT above.
MCP_SERVER_URL=http://aerostride-mcp-server:3000/sse

# Spring AI's OpenAI chat autoconfig is ON unless this is set to something other than
# 'openai'. Its openAiApi bean asserts the key is non-blank at STARTUP, so leaving this
# at 'openai' with an empty OPENAI_API_KEY crashes the backend before it serves anything.
# Set to 'openai' only when OPENAI_API_KEY below is filled in (needed for the MCP path).
SPRING_AI_MODEL_CHAT=none
# Phai bat/tat cung SPRING_AI_MODEL_CHAT o tren (xem application.properties).
SPRING_AI_CHAT_CLIENT_ENABLED=false

# Every var below is REQUIRED: application.properties maps them to properties that
# AiChatServiceImpl reads with no fallback (e.g. @Value("${google.gemini.api-key}")),
# so a missing one fails placeholder resolution and the backend never boots.
# The keys may be left EMPTY - initApiKeys() skips blank values and the chatbot
# falls back to AiLocalService. Multiple keys per provider: comma-separated.
# These four providers are called directly over REST and do NOT go through Spring AI,
# so they work regardless of SPRING_AI_MODEL_CHAT above.
GEMINI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.0-flash
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_BASE_URL=https://api.anthropic.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- FRONTEND CONFIG ---
# Dev server heap. The production build stage sets its own larger value.
NODE_OPTIONS=--max-old-space-size=512
VITE_API_URL=/api/v1
VITE_WS_URL=/ws
# Absolute public origin, NOT a path: index.html interpolates it as %VITE_APP_URL%
# into the JSON-LD SEO block (canonical url, logo, search action target).
VITE_APP_URL=https://aerostride.me

# --- FRONTEND PROXY ---
BACKEND_HOST=aerostride-be
# BACKEND_PORT đã được định nghĩa ở trên

# --- MAIL SERVER ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_DEBUG=false

# --- VNPay CONFIG ---
VNP_TMN_CODE=your_vnp_tmn_code
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_CLIENT_IP=127.0.0.1

# --- JWT SECURITY ---
# MUST be at least 64 bytes. JwtTokenProvider signs with HS512, and RFC 7518 requires
# a key of >= 512 bits for it; a shorter value throws WeakKeyException - under 32 bytes
# it kills startup in @PostConstruct, between 32 and 63 it boots fine and then fails on
# the first login, which is the more confusing of the two. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME__HS512_needs_at_least_64_bytes__replace_with_a_random_string_0123456789
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- APP BOOTSTRAP & SETTINGS ---
ORDER_CLEANUP_THRESHOLD_MS=86400000
# Guest chat history is deleted after this much inactivity (no new messages). Job interval below.
GUEST_CHAT_CLEANUP_THRESHOLD_MS=1800000
GUEST_CHAT_CLEANUP_INTERVAL_MS=300000
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_EMAIL=admin@aerostride.com
APP_BOOTSTRAP_ADMIN_PASSWORD=your_admin_password
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_NAME=Admin He Thong
APP_BOOTSTRAP_ADMIN_PHONE=0123456789
APP_BOOTSTRAP_ADMIN_BIRTH_DATE=2002-06-19
APP_BOOTSTRAP_ADMIN_GENDER=true
APP_LOCAL_UPLOAD_DIR=.local-uploads
BATCH_EXCEL_FILE_PATH=
LOGPATTERN_CONSOLE=%green(%d{HH:mm:ss.SSS}) %yellow(%-5level) %red([%thread]) %blue(%logger{255}) - %msg%n

# --- JVM & GRADLE CONFIG ---
# JAVA_OPTS is used ONLY by the production entrypoint (java -jar app.jar).
JAVA_OPTS=-Xms256m -Xmx768m -XX:+UseG1GC
# Dev: bootRun forks its own JVM, so it needs its own args (see BE/build.gradle).
# This app loads JPA + Batch + Security + WebFlux + Spring AI + Querydsl; below
# ~768m heap it spends its time in GC, which is what made the container feel slow.
BOOT_RUN_JVM_ARGS=-Xms256m -Xmx1g -XX:MaxMetaspaceSize=320m -XX:+UseG1GC -XX:TieredStopAtLevel=1
# Launcher JVM only - the Gradle daemon heap lives in docker/gradle.properties.dev.
# gradlew concatenates DEFAULT_JVM_OPTS + JAVA_OPTS + GRADLE_OPTS, so JAVA_OPTS
# leaks into the launcher too. GRADLE_OPTS comes last and must therefore set BOTH
# bounds, otherwise JAVA_OPTS' -Xms wins against this -Xmx and the VM refuses to
# start with "Initial heap size set to a larger value than the maximum heap size".
GRADLE_OPTS=-Xms64m -Xmx256m -Dfile.encoding=UTF-8
# Seconds between src/ mtime scans in the dev hot-reload watcher.
BE_WATCH_INTERVAL=2
GRADLE_DAEMON=true
GRADLE_PARALLEL=true
GRADLE_WORKERS_MAX=2
GRADLE_CONFIGURATION_CACHE=false
GRADLE_VFS_WATCH=false

# --- NGINX / DOMAIN ---
SERVER_NAME=localhost

# --- DOCKER BUILD CONFIG ---
DOCKER_BE_TARGET=development
DOCKER_FE_TARGET=development

# --- Container Internal Ports ---
BE_INTERNAL_PORT=8080
FE_INTERNAL_PORT=5173
FE_DEV_PORT=5173

# --- Volumes mapping ---
DOCKER_BE_VOL_APP=../BE:/app
DOCKER_BE_VOL_BUILD=
DOCKER_BE_VOL_GRADLE=
# Static gradle.properties mounted over /app/gradle.properties (shields container from
# host BE/gradle.properties if it contains ${ENV} placeholders Gradle can't parse).
DOCKER_BE_GRADLE_PROPS=./gradle.properties.dev:/app/gradle.properties:ro
DOCKER_FE_VOL_APP=../FE:/app
DOCKER_FE_VOL_NODE=/app/node_modules

# --- MOBILE (Expo dev server) ---
DOCKER_MOBILE_TARGET=development
MOBILE_INTERNAL_PORT=8081
MOBILE_PORT_HOST=8081
DOCKER_MOBILE_VOL_APP=../mobile:/app
# Origin only (mobile/src/config/api.ts appends /api/v1 and derives the ws URL).
# The browser runs on the host, so it must reach the backend's published port,
# not the compose-internal hostname.
EXPO_PUBLIC_API_URL=http://localhost:8080
# Metro bundling a React Native tree is memory hungry; this is the peak, not idle.
MOBILE_MEMORY_LIMIT=1024M
MOBILE_MEMORY_RESERVATION=256M

# --- DOCKER COMPOSE RESOURCE LIMITS ---
# Sized for an 8GB host with WSL2 capped at 5GB (see %USERPROFILE%\.wslconfig).
# Sum of the always-on services below is ~4.2GB, leaving headroom for the Docker
# daemon itself. Raise BACKEND_MEMORY_LIMIT first if you get more RAM.
# Backend: holds the app JVM (~1.4G) + two Gradle daemons (bootRun and the
# hot-reload watcher). 1G was not enough for even one of them.
BACKEND_MEMORY_LIMIT=2304M
BACKEND_MEMORY_RESERVATION=512M
# Frontend: Vite dev server only; it does not need the production build heap.
# Measured at ~66M idle, so 512M is already generous.
FRONTEND_MEMORY_LIMIT=512M
FRONTEND_MEMORY_RESERVATION=256M
FRONTEND_CPU_LIMIT=1.0
FRONTEND_CPU_RESERVATION=0.25
# MySQL: measured at ~444M against a 512M limit (87%) - too close to the OOM
# killer once Flyway and the batch jobs run. The headroom comes from the frontend.
MYSQL_MEMORY_LIMIT=768M
MYSQL_MEMORY_RESERVATION=256M
# Redis
REDIS_MEMORY_LIMIT=128M
REDIS_MEMORY_RESERVATION=64M
# MCP Server
MCP_SERVER_MEMORY_LIMIT=128M
MCP_SERVER_MEMORY_RESERVATION=32M

# --- DOCKER COMPOSE SERVICE CONFIG ---
# unless-stopped, not always: a backend that fails to boot on bad config should
# stay down so you can read the logs, instead of looping.
DOCKER_RESTART_POLICY=unless-stopped
DOCKER_NETWORK=aerostride-net

# --- SPRING DEVTOOLS CONFIG ---
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_RESTART_POLL_INTERVAL=3s
SPRING_DEVTOOLS_RESTART_QUIET_PERIOD=2s

# --- FILE WATCHING CONFIG ---
# On Windows + Docker bind mounts, polling is REQUIRED for Vite hot reload to work.
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
