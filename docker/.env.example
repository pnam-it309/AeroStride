# ==============================================================================
# AEROSTRIDE - ENVIRONMENT CONFIGURATION (.env.example)
# Copy file này thành .env và điền giá trị thật
# ==============================================================================

# --- DOCKER IMAGES ---
BACKEND_IMAGE=aerostride-backend:dev
FRONTEND_IMAGE=aerostride-frontend:dev

# --- NETWORKING PORTS ---
BACKEND_PORT=8080
NGINX_PORT=80
FE_PORTExternal=5173

# --- DATABASE (MYSQL) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_PORT_HOST=3307
MYSQL_DATABASE=aerostride_db
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/aerostride_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_user
SPRING_DATASOURCE_PASSWORD=your_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# --- REDIS ---
REDIS_HOST=redis
REDIS_PORT=6379
SPRING_CACHE_TYPE=redis

# --- APP SETTINGS ---
SPRING_PROFILES_ACTIVE=mysql
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_API_PREFIX=/api/v1
ALLOWED_ORIGIN=http://localhost:5173
ACTUATOR_ENDPOINTS=health,info,metrics

# --- FRONTEND CONFIG ---
NODE_OPTIONS=--max-old-space-size=4096
VITE_API_URL=/api/v1
VITE_WS_URL=/ws
VITE_APP_NAME=AeroStride
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# --- FRONTEND PROXY ---
BACKEND_HOST=aerostride-be
# BACKEND_PORT đã được định nghĩa ở trên

# --- MAIL SERVER ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_DEBUG=false

# --- VNPay CONFIG ---
VNP_TMN_CODE=your_vnp_tmn_code
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_CLIENT_IP=127.0.0.1

# --- JWT SECURITY ---
JWT_SECRET=your_jwt_secret_key_at_least_64_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- CLOUDINARY ---
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# --- APP BOOTSTRAP & SETTINGS ---
ORDER_CLEANUP_THRESHOLD_MS=86400000
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_EMAIL=admin@aerostride.com
APP_BOOTSTRAP_ADMIN_PASSWORD=your_admin_password
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_NAME=Admin He Thong
APP_BOOTSTRAP_ADMIN_PHONE=0123456789
APP_BOOTSTRAP_ADMIN_BIRTH_DATE=2002-06-19
APP_BOOTSTRAP_ADMIN_GENDER=true
APP_LOCAL_UPLOAD_DIR=.local-uploads
BATCH_EXCEL_FILE_PATH=
LOGPATTERN_CONSOLE=%green(%d{HH:mm:ss.SSS}) %yellow(%-5level) %red([%thread]) %blue(%logger{255}) - %msg%n

# --- JVM & GRADLE CONFIG ---
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC
GRADLE_OPTS=-Xmx2g -XX:MaxMetaspaceSize=512m -XX:TieredStopAtLevel=1 -Dfile.encoding=UTF-8

# --- NGINX / DOMAIN ---
SERVER_NAME=localhost

# --- DOCKER BUILD CONFIG ---
DOCKER_BE_TARGET=development
DOCKER_FE_TARGET=development

# --- Container Internal Ports ---
BE_INTERNAL_PORT=8080
FE_INTERNAL_PORT=5173
FE_DEV_PORT=5173

# --- Volumes mapping ---
DOCKER_BE_VOL_APP=../BE:/app
DOCKER_BE_VOL_BUILD=
DOCKER_BE_VOL_GRADLE=
DOCKER_FE_VOL_APP=../FE:/app
DOCKER_FE_VOL_NODE=/app/node_modules