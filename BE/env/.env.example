# ==============================================================================
# AEROSTRIDE - BACKEND ENVIRONMENT (running BE directly, NOT via Docker)
# For the containerised stack use docker/.env.example instead.
# ==============================================================================

SPRING_PROFILES_ACTIVE=mysql

# SERVER
SERVER_PORT=8080
APP_API_PREFIX=/api/v1
APP_BASE_URL=http://localhost:8080
# Public storefront origin for absolute SEO URLs (product sitemap). /product/{id}
# is a frontend route, so this is the FE host, not the API host.
APP_PUBLIC_URL=http://localhost:5173

# DATABASE
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=aerostride_db
MYSQL_USER=aerostride_user
MYSQL_PASSWORD=your_user_password
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/aerostride_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=aerostride_user
SPRING_DATASOURCE_PASSWORD=your_user_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
SPRING_CACHE_TYPE=simple

# MAIL SERVER
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_DEBUG=false

# VNPAY
VNP_TMN_CODE=your_vnp_tmn_code
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_CLIENT_IP=127.0.0.1
ORDER_CLEANUP_THRESHOLD_MS=86400000

# SECURITY
# MUST be >= 64 bytes: JwtTokenProvider signs with HS512 and jjwt rejects shorter keys.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME__HS512_needs_at_least_64_bytes__replace_with_a_random_string_0123456789
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
# Comma-separated (SecurityConfig splits it): Vite app + Expo web.
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:8081

# AI CHATBOT
# Keep 'none' unless OPENAI_API_KEY is real: Spring AI's OpenAI autoconfig asserts a
# non-blank key at startup, so 'openai' + empty key means the backend refuses to boot.
SPRING_AI_MODEL_CHAT=none
# Phai bat/tat cung SPRING_AI_MODEL_CHAT o tren (xem application.properties).
SPRING_AI_CHAT_CLIENT_ENABLED=false

GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GEMINI_MODEL=gemini-2.0-flash
GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000

# OPENAI CHATGPT
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ANTHROPIC CLAUDE
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# DEEPSEEK
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DEFAULT ADMIN BOOTSTRAP
APP_BOOTSTRAP_ADMIN_ENABLED=true
APP_BOOTSTRAP_ADMIN_EMAIL=nguyenhuyducbg19062002@gmail.com
APP_BOOTSTRAP_ADMIN_PASSWORD=123456
APP_BOOTSTRAP_ADMIN_USERNAME=admin.aerostride
APP_BOOTSTRAP_ADMIN_NAME=Nguyen Huy Duc
APP_BOOTSTRAP_ADMIN_PHONE=0123456789
APP_BOOTSTRAP_ADMIN_BIRTH_DATE=2002-06-19
APP_BOOTSTRAP_ADMIN_GENDER=true

# APP & LOGGING
# Required: application.properties references these with no fallback.
ACTUATOR_ENDPOINTS=health,info,metrics
APP_LOCAL_UPLOAD_DIR=.local-uploads
BATCH_EXCEL_FILE_PATH=
LOGPATTERN_CONSOLE=%green(%d{HH:mm:ss.SSS}) %yellow(%-5level) %red([%thread]) %blue(%logger{255}) - %msg%n
