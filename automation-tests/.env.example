# ==============================================================================
# AEROSTRIDE - AUTOMATION TESTS ENVIRONMENT (.env.example)
#
# HEADS UP: Playwright does NOT read .env by itself, and this package has no
# dotenv dependency, so copying this to .env alone changes nothing. Export the
# values instead:
#     BASE_URL=http://localhost:8080 npm run test:api
# or   set -a; . ./.env; set +a; npm test
# (To make .env load automatically: npm i -D dotenv, then add
#  require('dotenv').config() at the top of playwright.config.js.)
#
# Every value below is optional - the defaults baked into the configs are
# documented so you can see what you get by NOT setting them.
# ==============================================================================

# --- TARGET UNDER TEST ---
# Consumed by playwright.config.js (`use.baseURL`).
# DEFAULT WHEN UNSET: https://aerostride.me - the LIVE site. The API suite in
# tests/api/aerostride-flows.spec.js creates real schedules and deletes them in
# teardown, so an unset BASE_URL writes to production. Point this at a local
# stack unless you deliberately want to exercise the deployed environment.
#   local backend  : http://localhost:8080
#   local frontend : http://localhost:5173
#   test compose   : http://backend-server-test:8080 (set by docker-compose.test.yml)
BASE_URL=http://localhost:8080

# --- SELENIUM SUITES (tests/selenium/*.js) ---
# Which browser selenium-webdriver launches. DEFAULT WHEN UNSET: chrome
BROWSER=chrome
# Headless unless explicitly the string "false". DEFAULT WHEN UNSET: headless.
HEADLESS=false

# --- CI ---
# Playwright reads this itself: when set, forbidOnly=true and retries=2.
# Your CI provider normally sets it; leave it unset locally.
# CI=true
